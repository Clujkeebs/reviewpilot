# ── SMS / Twilio (operator credentials — customers never see this) ──────────
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── Anthropic ────────────────────────────────────────────────────────────────
# Get your key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── App config ───────────────────────────────────────────────────────────────
PORT=3000

# ── Auth ─────────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a random 64+ character string in production!
JWT_SECRET=change-this-to-a-random-64-char-string-before-deploying

# ── Admin ────────────────────────────────────────────────────────────────────
# Secret key to access /api/leads and /api/audit-leads admin endpoints
ADMIN_KEY=change-this-to-a-random-string

# ── App URL ──────────────────────────────────────────────────────────────────
# Your deployed domain (used for password reset links, Stripe callbacks, etc.)
APP_URL=https://starpush.io

# ── Email / SMTP (optional but recommended for password reset + welcome) ─────
# Works with Gmail (use an App Password), SendGrid, Resend, etc.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=Starpush <hello@starpush.io>

# ── Stripe ───────────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_STARTER_PRICE_ID=price_...
# STRIPE_GROWTH_PRICE_ID=price_...
# STRIPE_PRO_PRICE_ID=price_...
